@dataclass
class LinkItem:
    email: str
    code_address: str
    link: str
    raw_line: str


def _display_proxy(proxy: str | None) -> str:
    if not proxy:
        return "无"
    text = proxy.strip()
    if "@" in text:
        prefix, suffix = text.rsplit("@", 1)
        scheme = prefix.split("://", 1)[0] + "://" if "://" in prefix else ""
        return f"{scheme}***:***@{suffix}"
    return text


def _normalize_proxy(value: str | None) -> str | None:
    if not value:
        return None
    raw = value.strip().lstrip("\ufeff\u200b\u2060")
    if not raw:
        return None
    if "://" not in raw:
        raw = f"http://{raw}"
    return raw


def _probe_proxy(proxy: str, timeout_sec: int = 10) -> tuple[bool, str]:
    try:
        resp = requests.get("http://example.com", proxies={"http": proxy, "https": proxy}, timeout=timeout_sec)
        return (resp.status_code == 200), f"http={resp.status_code}"
    except Exception as exc:  # noqa: BLE001
        return False, f"{type(exc).__name__}: {exc}"


def load_link_pool() -> list[LinkItem]:
    if not LINK_POOL_FILE.exists():
        return []
    items: list[LinkItem] = []
    seen: set[str] = set()
    for line in LINK_POOL_FILE.read_text(encoding="utf-8", errors="ignore").splitlines():
        text = line.strip().lstrip("\ufeff\u200b\u2060")
        if not text or text.startswith("#"):
            continue
        parts = [p.strip() for p in text.split("----")]
        if len(parts) < 3:
            continue
        email, code_address, link = parts[0], parts[1], parts[2]
        if "@" not in email or not link.startswith(("http://", "https://")):
            continue
        key = email.lower()
        if key in seen:
            continue
        seen.add(key)
        items.append(LinkItem(email=email, code_address=code_address, link=link, raw_line=text))
    return items


def remove_from_link_pool(email: str) -> None:
    if not LINK_POOL_FILE.exists():
        return
    lines = LINK_POOL_FILE.read_text(encoding="utf-8", errors="ignore").splitlines()
    kept: list[str] = []
    for line in lines:
        text = line.strip()
        if not text or text.startswith("#"):
            kept.append(line)
            continue
        parts = [p.strip() for p in text.split("----")]
        if parts and parts[0].lower() == email.lower():
            continue
        kept.append(line)
    LINK_POOL_FILE.write_text("\n".join(kept) + ("\n" if kept else ""), encoding="utf-8")


def save_pending_auth(email: str, code_address: str) -> None:
    PENDING_AUTH_DIR.mkdir(parents=True, exist_ok=True)
    if not PENDING_AUTH_FILE.exists():
        PENDING_AUTH_FILE.write_text("", encoding="utf-8")
    existing = PENDING_AUTH_FILE.read_text(encoding="utf-8", errors="ignore").splitlines()
    kept = [ln for ln in existing if not ln.strip().lower().startswith(email.lower() + "----")]
    kept.append(f"{email}----{code_address}")
    PENDING_AUTH_FILE.write_text("\n".join(kept) + "\n", encoding="utf-8")


def generate_paypal_password() -> str:
    alphabet = string.ascii_letters + string.digits
    return "Lc" + "".join(secrets.choice(alphabet) for _ in range(16)) + "9!"


def _extract_latest_code(text: str, exclude: set[str] | None = None) -> str | None:
    found = extract_codes(text or "")
    if not found:
        return None
    bad = exclude or set()
    for code in found:
        if code not in bad:
            return code
    return None


def poll_sms_code(phone: PhoneInfo, *, timeout_sec: int = 120, interval_sec: int = 4, exclude: set[str] | None = None) -> str:
    deadline = time.time() + max(10, timeout_sec)
    last_err = ""
    while time.time() < deadline:
        try:
            resp = requests.get(phone.api_url, timeout=15)
            body = (resp.text or "").strip()
            code = _extract_latest_code(body, exclude=exclude)
            if code:
                log(f"[SMS] 已从手机号 API 提取验证码: {code}")
                return code
            last_err = body[:120]
        except Exception as exc:  # noqa: BLE001
            last_err = f"{type(exc).__name__}: {exc}"
        time.sleep(max(1, interval_sec))
    raise TimeoutError(f"手机号验证码超时，最后响应: {last_err}")


async def _fill_input_if_visible(page, selectors: list[str], value: str, *, timeout_ms: int = 1500) -> bool:
    for sel in selectors:
        try:
            loc = page.locator(sel).first
            if await loc.is_visible(timeout=timeout_ms):
                await loc.fill(value, timeout=timeout_ms)
                return True
        except Exception:
            pass
    return False


