async def _select_card_payment_method_if_needed(page) -> bool:
    try:
        return bool(await page.evaluate(
            """() => {
                const text = (el) => (el?.innerText || el?.textContent || '').trim();
                const visible = (el) => !!el && el.offsetParent !== null;
                const radios = Array.from(document.querySelectorAll('input[type="radio"]'));
                if (!radios.length) return true;
                const anyChecked = radios.some(r => r.checked);
                if (anyChecked) return true;

                // Prefer card/bank-card option and avoid PayPal option.
                const labels = Array.from(document.querySelectorAll('label, div, button, span'));
                for (const el of labels) {
                    if (!visible(el)) continue;
                    const t = text(el).toLowerCase();
                    if (!t) continue;
                    if ((t.includes('银行卡') || t.includes('bank card') || t.includes('card')) && !t.includes('paypal')) {
                        try { el.click(); } catch {}
                    }
                }

                // Fallback: click first visible unchecked radio.
                for (const r of radios) {
                    if (!visible(r)) continue;
                    if (!r.checked) {
                        try { r.click(); } catch {}
                        if (r.checked) return true;
                        const id = r.getAttribute('id');
                        if (id) {
                            const lb = document.querySelector(`label[for="${id}"]`);
                            if (lb) { try { lb.click(); } catch {} }
                        }
                    }
                }
                return Array.from(document.querySelectorAll('input[type="radio"]')).some(r => r.checked);
            }"""
        ))
    except Exception:
        return False


async def _check_agreement_if_needed(page) -> bool:
    try:
        return bool(await page.evaluate(
            """() => {
                const visible = (el) => !!el && el.offsetParent !== null;
                const text = (el) => (el?.innerText || el?.textContent || '').toLowerCase();
                const boxes = Array.from(document.querySelectorAll('input[type="checkbox"]')).filter(visible);
                if (!boxes.length) return true;

                let target = null;
                for (const box of boxes) {
                    const container = box.closest('label, div, section, form') || box.parentElement;
                    const t = text(container || box);
                    if (/同意|条款|授权|agree|authorize|openai opco|subscription/i.test(t)) {
                        target = box;
                        break;
                    }
                }
                if (!target) target = boxes[0];
                if (!target.checked) {
                    try { target.click(); } catch {}
                    if (!target.checked) {
                        const id = target.getAttribute('id');
                        if (id) {
                            const lb = document.querySelector(`label[for="${id}"]`);
                            if (lb) { try { lb.click(); } catch {} }
                        }
                    }
                }
                return !!target.checked;
            }"""
        ))
    except Exception:
        return False


async def _checkout_readiness(page) -> dict[str, bool]:
