async def fill_stripe(page, card: CardInfo, email: str, prefix: str = "[PayPal]") -> None:
    await page.wait_for_timeout(1200)

    await _fill_input_if_visible(page, [
        'input[type="email"]',
        'input[name="email"]',
        'input[autocomplete="email"]',
    ], email)

    await _fill_input_if_visible(page, [
        'input[name="cardnumber"]',
        'input[autocomplete="cc-number"]',
        'input[placeholder*="card" i]',
        'input[aria-label*="card number" i]',
    ], card.number)

    await _fill_input_if_visible(page, [
        'input[name="exp-date"]',
        'input[autocomplete="cc-exp"]',
        'input[aria-label*="expiration" i]',
    ], f"{card.exp_month}/{card.exp_year}")

    await _fill_input_if_visible(page, [
        'input[name="cvc"]',
        'input[autocomplete="cc-csc"]',
        'input[aria-label*="security code" i]',
    ], card.cvv)

    await _fill_input_if_visible(page, [
        'input[name="name"]',
        'input[autocomplete="cc-name"]',
        'input[placeholder*="name" i]',
    ], card.holder_name or f"{card.first_name} {card.last_name}")

    await _fill_input_if_visible(page, ['input[name="addressLine1"]', 'input[autocomplete="address-line1"]'], card.street)
    await _fill_input_if_visible(page, ['input[name="city"]', 'input[autocomplete="address-level2"]'], card.city)
    await _fill_input_if_visible(page, ['input[name="state"]', 'input[autocomplete="address-level1"]'], card.state)
    await _fill_input_if_visible(page, ['input[name="postalCode"]', 'input[autocomplete="postal-code"]'], card.zip_code)

    # Stripe 常见 iframe 输入框（宽松尝试，避免过早失败）
    frame_selectors = [
        'iframe[title*="card number" i]',
        'iframe[name*="__privateStripeFrame" i]',
        'iframe[src*="stripe" i]',
    ]
    for fsel in frame_selectors:
        try:
            fl = page.frame_locator(fsel)
            await fl.locator('input[name="cardnumber"], input[autocomplete="cc-number"]').first.fill(card.number, timeout=1000)
            await fl.locator('input[name="exp-date"], input[autocomplete="cc-exp"]').first.fill(f"{card.exp_month}/{card.exp_year}", timeout=1000)
            await fl.locator('input[name="cvc"], input[autocomplete="cc-csc"]').first.fill(card.cvv, timeout=1000)
            break
        except Exception:
            pass

    submitted = await _click_if_visible(page, [
        'button:has-text("Pay")',
        'button:has-text("支付")',
        'button:has-text("Subscribe")',
        'button:has-text("订阅")',
        'button[type="submit"]',
    ], timeout_ms=2200)

    if submitted:
        log(f"{prefix} 已提交支付表单")
    else:
        log(f"{prefix} 未定位到明显支付按钮，继续观察页面")


async def _detect_captcha(page) -> bool:
    try:
        result = await page.evaluate(
            r"""() => {
                const text = (document.body?.innerText || '').replace(/\s+/g, ' ');
                const tokenCandidates = [
                    document.querySelector('textarea[name="g-recaptcha-response"]')?.value || '',
                    document.querySelector('#g-recaptcha-response')?.value || '',
                    document.querySelector('textarea[name="h-captcha-response"]')?.value || '',
                    document.querySelector('input[name="g-recaptcha-response"]')?.value || '',
                    document.querySelector('input[name="h-captcha-response"]')?.value || '',
                ];
                const hasToken = tokenCandidates.some(v => (v || '').trim().length > 20);
                const hasCaptchaText = /安全问题|Security Challenge|请选择包含|Select all images|crosswalk|traffic light|bus|bicycle/i.test(text);
                const allFrames = Array.from(document.querySelectorAll('iframe[src]')).map(f => (f.getAttribute('src') || '').toLowerCase());
                const hasChallengeFrame = allFrames.some(src => {
                    if (!src) return false;
                    if (src.includes('js.stripe.com') && src.includes('hcaptcha-invisible')) return false;
                    if (src.includes('recaptcha/api2/bframe')) return true;
                    if (src.includes('hcaptcha') && src.includes('challenge')) return true;
                    return false;
                }) || !!document.querySelector('iframe[title*="challenge" i]');
                const hasPaypalChallenge = !!document.querySelector('[data-testid="captcha"], .captcha-container, #captcha, [class*="captcha" i]');
                if (hasToken && !hasCaptchaText && !hasPaypalChallenge) return false;
                return hasCaptchaText || hasChallengeFrame || hasPaypalChallenge;
            }"""
        )
        return bool(result)
    except Exception:
        return False


async def _extract_captcha_info(page) -> dict[str, Any]:
    return await page.evaluate(
        r"""() => {
            const pickQuery = (src, keys) => {
                try {
                    const u = new URL(src, location.href);
                    const want = new Set((keys || []).map(k => String(k).toLowerCase()));
                    for (const [k, v] of u.searchParams.entries()) {
                        if (want.has(String(k).toLowerCase()) && (v || '').trim()) return String(v).trim();
                    }
                    return '';
                } catch { return ''; }
            };
            const toAbs = (src) => { try { return new URL(src, location.href).href; } catch { return location.href; } };
            const frames = Array.from(document.querySelectorAll('iframe[src]')).map(f => f.getAttribute('src') || '').filter(Boolean);
            const hints = frames.filter(src => /recaptcha|hcaptcha|captcha|challenge|turnstile/i.test(src)).slice(0, 8);
            const isEnterprise = !!window.grecaptcha?.enterprise || !!document.querySelector('script[src*="recaptcha/enterprise"]');

            const byDataSitekey = document.querySelector('[data-sitekey], .g-recaptcha, .h-captcha');
            if (byDataSitekey) {
                const sk = byDataSitekey.getAttribute('data-sitekey') || '';
                if (sk) {
                    return { provider: /h-captcha/i.test(byDataSitekey.className || '') ? 'hcaptcha' : 'recaptcha', sitekey: sk, solve_url: location.href, enterprise: isEnterprise, invisible: ((byDataSitekey.getAttribute('data-size') || '').toLowerCase() === 'invisible'), callback: byDataSitekey.getAttribute('data-callback') || null, reason: 'found data-sitekey element', frame_hints: hints, recaptcha_version: 'v2', action: '' };
                }
            }

            const recFrames = frames.filter(src => /recaptcha/i.test(src));
            if (recFrames.length) {
                let best = recFrames[0];
                let bestKey = '';
                for (const src of recFrames) {
                    const k = pickQuery(src, ['k', 'sitekey', 'siteKey', 'render']);
                    if (k) { best = src; bestKey = k; break; }
                }
                const low = best.toLowerCase();
                const action = pickQuery(best, ['action']);
                const isV3 = /recaptcha_v3/.test(low) || (/api\.js/.test(low) && /(?:\?|&)render=/.test(low));
                const dataS = pickQuery(best, ['s', 'data-s']);
                return { provider: 'recaptcha', sitekey: bestKey ? decodeURIComponent(bestKey) : '', solve_url: location.href, iframe_url: toAbs(best), data_s: dataS || '', enterprise: isEnterprise, invisible: /size=invisible/i.test(best), callback: null, reason: bestKey ? 'found recaptcha iframe key param' : 'recaptcha iframe exists but no key param', frame_hints: hints, recaptcha_version: isV3 ? 'v3' : 'v2', action: action || '' };
            }

            const hFrame = frames.find(src => /hcaptcha/i.test(src) && !/js\.stripe\.com\/v3\/hcaptcha-invisible/i.test(src));
            if (hFrame) {
                const sk = pickQuery(hFrame, ['sitekey', 'siteKey']);
                return { provider: 'hcaptcha', sitekey: sk ? decodeURIComponent(sk) : '', solve_url: location.href, iframe_url: toAbs(hFrame), data_s: '', enterprise: false, invisible: /invisible/i.test(hFrame), callback: null, reason: sk ? 'found hcaptcha iframe sitekey' : 'hcaptcha iframe exists but no sitekey param', frame_hints: hints, recaptcha_version: 'v2', action: '' };
            }

            return { provider: 'unknown', sitekey: '', solve_url: location.href, iframe_url: '', data_s: '', enterprise: false, invisible: false, callback: null, reason: 'no supported recaptcha/hcaptcha sitekey found', frame_hints: hints, recaptcha_version: 'v2', action: '' };
        }"""
    )


