MAIL_SOURCE=moemail
FLOW1_MAIL_SOURCE=moemail
FLOW3_MAIL_SOURCE=moemail
FREE_MAIL_SOURCE=moemail
MAIL_FETCH_SOURCE=
EXTERNAL_IMAP163_DIR=
IMAP163_FORWARD_DOMAIN=
PAYPAL_REGISTER_USE_PROXY=false
PAYPAL_REGISTER_PROXY_FILE=data/proxies/proxies_jp.txt
FLOW1_SMS_ENABLED=true
FLOW1_SMS_PROVIDER=herosms
FLOW3_SMS_ENABLED=true
FLOW3_SMS_PROVIDER=herosms
FREE_SMS_ENABLED=true
FREE_SMS_PROVIDER=herosms
MAIL_ACCOUNT_MODE=pool
USE_PROXY=false
PROXY_FILE=data/proxies/proxies.txt
GOPAY_PHONE_1=15700000001
GOPAY_PHONE_2=15700000002
GOPAY_PHONE_3=15700000003
# 兼容旧配置：未填写 GOPAY_PHONE_1/2/3 时，会按顺序映射到 worker-1/2/3。
GOPAY_PHONES=15700000001,15700000002,15700000003
GOPAY_COUNTRY_CODE=+62
GOPAY_PIN=123456
FLOW2_BILLING_RETRIES=5
FLOW2_OTP_TIMEOUT=90
FLOW2_RETRY_INTERVAL=6
FLOW2_RETRY_TIMEOUT=180
FLOW2_MANUAL_SUCCESS_TIMEOUT=180
FLOW2_SAVE_SUCCESS_SCREENSHOTS=false

# 流程 2 GoPay WhatsApp OTP 自动取码。默认关闭，开启后会通过 ADB 读取手机通知/当前页面文本。
WHATSAPP_OTP_AUTO=false
WHATSAPP_ADB_PATH=tools\adb\adb.exe
# 多线程可分别绑定设备；单设备可只填 WHATSAPP_ADB_DEVICE。
WHATSAPP_ENABLED_1=true
WHATSAPP_ADB_DEVICE_1=
WHATSAPP_ENABLED_2=true
WHATSAPP_ADB_DEVICE_2=
WHATSAPP_ENABLED_3=true
WHATSAPP_ADB_DEVICE_3=
WHATSAPP_PACKAGE_1=com.whatsapp
WHATSAPP_PACKAGE_2=com.whatsapp
WHATSAPP_PACKAGE_3=com.whatsapp
WHATSAPP_CODE_TIMEOUT=90
WHATSAPP_CODE_INTERVAL=2
WHATSAPP_USE_BRIDGE=true
WHATSAPP_BRIDGE_PACKAGE=com.loucer.otpbridge
WHATSAPP_BRIDGE_AUTHORITY=com.loucer.otpbridge.notifications
WHATSAPP_USE_NOTIFICATIONS=false
WHATSAPP_USE_UI_TEXT=false
WHATSAPP_AUTO_OPEN=false
WHATSAPP_WAKE_BEFORE_OPEN=true
WHATSAPP_SAVE_SCREENSHOT=false
# OCR 需要额外安装 pillow/pytesseract/Tesseract，先默认关闭。
WHATSAPP_USE_OCR=false

# 流程 2 支付成功后，用 ADB 打开 GoPay 并解绑 OpenAI LLC linked app。
GOPAY_UNLINK_AFTER_SUCCESS=false
GOPAY_UNLINK_ENABLED_1=true
GOPAY_ADB_DEVICE_1=
GOPAY_UNLINK_ENABLED_2=true
GOPAY_ADB_DEVICE_2=
GOPAY_UNLINK_ENABLED_3=true
GOPAY_ADB_DEVICE_3=
GOPAY_PACKAGE=com.gojek.gopay
GOPAY_UNLINK_TARGET_APP=OpenAI LLC
GOPAY_UNLINK_SAVE_SCREENSHOT=true
GOPAY_UNLINK_DEBUG_SCREENSHOTS=false
GOPAY_UNLINK_FAST_TAPS=true
FLOW2_SAVE_SUCCESS_SCREENSHOTS=false

# MoeMail 服务端配置。MAIL_ACCOUNT_MODE=api 时会自动创建邮箱补足流程 1 账号池。
# 可用域名目前只支持这三个。
MOEMAIL_ENABLED=false
MOEMAIL_BASE_URL=https://mail.example.com
MOEMAIL_API_KEY=change-me
MOEMAIL_DOMAIN_WHITELIST=intereloucer.com,interestedloucer.com,interestloucered.com
MOEMAIL_DOMAIN_MODE=random
MOEMAIL_FIXED_DOMAIN=intereloucer.com
FREE_MOEMAIL_DOMAIN_MODE=random
FREE_MOEMAIL_FIXED_DOMAIN=intereloucer.com
MOEMAIL_CREATE_PREFIX=openai
MOEMAIL_CREATE_MODE=human

# iCloud 查询码账号池示例：
# data/icloud/accounts.txt
# 格式：邮箱----查询码

# 流程 3 授权完成后上传服务器账号库。
# 不需要上传就设为 false。
AUTH_SERVER_UPLOAD=false
AUTH_SERVER_URL=http://127.0.0.1:8790
AUTH_SERVER_API_KEY=change-me

# 流程 4 Session 导出是否上传服务器。地址和 API Key 复用上面的 AUTH_SERVER_URL/AUTH_SERVER_API_KEY。
SESSION_EXPORT_SERVER_UPLOAD=false
AUTH_SERVER_HOST=0.0.0.0
AUTH_SERVER_PORT=8790
AUTH_SERVER_DB=服务器/data/accounts.db

# 流程 1 注册阶段、流程 3 授权阶段手机号必填页自动接码。
# SMS_PROVIDER 可选 herosms / grizzly / fivesim。流程专属 FLOW1/FLOW3/FREE_SMS_PROVIDER 可覆盖默认平台。
SMS_ENABLED=true
SMS_PROVIDER=herosms
HERO_SMS_API_KEY=
HERO_SMS_SERVICE=dr
HERO_SMS_COUNTRY_TOP_N=10
HERO_SMS_OPERATOR_THRESHOLD=20
HERO_SMS_PROMPT_OPERATOR_SELECTION=true
HERO_SMS_POLL_INTERVAL=5
HERO_SMS_MAX_ATTEMPTS=60
# 可选：跳过国家交互，指定 ISO 或 HeroSMS 国家 ID，例如 US / 187。
HERO_SMS_COUNTRY_SELECT=
HERO_SMS_PROMPT_COUNTRY_SELECTION=true

# GrizzlySMS。GRIZZLY_SERVICE=auto 会从服务列表自动识别 OpenAI/ChatGPT，识别失败回退 dr。
GRIZZLY_API_KEY=
GRIZZLY_SERVICE=auto
GRIZZLY_COUNTRY_TOP_N=10
GRIZZLY_PROVIDER_THRESHOLD=20
GRIZZLY_PROMPT_PROVIDER_SELECTION=true
GRIZZLY_POLL_INTERVAL=5
GRIZZLY_MAX_ATTEMPTS=60
# 可选：跳过国家交互，指定 ISO 或 GrizzlySMS 国家 ID，例如 US / 187。
GRIZZLY_COUNTRY_SELECT=
GRIZZLY_PROMPT_COUNTRY_SELECTION=true

# 5sim.net 接码平台。API Key 在 https://5sim.net/settings/security 创建（Bearer JWT）。
# FIVESIM_SERVICE 默认 openai（ChatGPT 注册）。
# FIVESIM_COUNTRY_SELECT 填 ISO 代码（ID / VN / PH）或 5sim slug（indonesia）。
FIVESIM_API_KEY=
FIVESIM_SERVICE=openai
FIVESIM_COUNTRY_TOP_N=10
FIVESIM_OPERATOR_THRESHOLD=20
FIVESIM_PROMPT_OPERATOR_SELECTION=false
FIVESIM_POLL_INTERVAL=5
FIVESIM_MAX_ATTEMPTS=60
FIVESIM_COUNTRY_SELECT=
FIVESIM_PROMPT_COUNTRY_SELECTION=true

# ============ PayPal 人机验证码处理 ============
# 模式：manual = 暂停等手动处理（默认），api = 调用打码平台自动解
PAYPAL_CAPTCHA_MODE=manual
# 手动模式等待超时（秒），超时后继续尝试
PAYPAL_CAPTCHA_TIMEOUT=180

# 打码平台配置（PAYPAL_CAPTCHA_MODE=api 时生效）
# 支持 capsolver 或 twocaptcha
CAPTCHA_API_PROVIDER=capsolver

# CapSolver（推荐，速度快，支持 reCAPTCHA/hCaptcha）
# 注册：https://www.capsolver.com/  价格约 $0.8-2/1000次
CAPSOLVER_API_KEY=

# 2Captcha（老牌平台，人工打码）
# 注册：https://2captcha.com/  价格约 $2-3/1000次
TWOCAPTCHA_API_KEY=

# ============ PayPal 代理配置 ============
# 开关：是否为 PayPal 流程启用代理（每个线程走不同代理）
PAYPAL_USE_PROXY=false
# 代理文件路径（默认复用全局代理文件）
# 格式：每行一个，支持 http://user:pass@host:port 或 socks5://host:port
PAYPAL_PROXY_FILE=data/proxies/proxies.txt

# PayPal 卡密自动兑换（从卡密池自动兑换并写入 cards.txt）
PAYPAL_CARD_REDEEM_ENABLED=true
PAYPAL_CARD_REDEEM_API_URL=https://card.52bankcard.com/api/exchange/verify
PAYPAL_CARD_REDEEM_API_KEY=
PAYPAL_CARD_REDEEM_CODE_FIELD=key
PAYPAL_CARD_REDEEM_TIMEOUT=20
PAYPAL_CARD_REDEEM_MAX_AUTO_FETCH=20
PAYPAL_CARD_REDEEM_APPEND_WHEN_STATUS_USED=true
PAYPAL_CARD_CODES_FILE=data/paypal/card_codes.txt
PAYPAL_CARD_CODES_USED_FILE=data/paypal/card_codes_used.txt
PAYPAL_CARD_CODES_FAILED_FILE=data/paypal/card_codes_failed.txt
